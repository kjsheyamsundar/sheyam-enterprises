# Sheyam Enterprises — environment variables (template)
# Copy this file to `.env.local` and fill in the real values.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# ─────────────────────────────────────────────
# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
# Leave blank in dev to disable tracking entirely.
# ─────────────────────────────────────────────
VITE_GA_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────
# Production site URL (used by SEO canonical + sitemap)
# ─────────────────────────────────────────────
VITE_SITE_URL=https://sheyamenterprises.com

# ─────────────────────────────────────────────
# Web3Forms access key — receives enquiry-form submissions
# at sheyamenterprises@gmail.com.
# Get one (no signup) at https://web3forms.com — enter the
# destination email and the key arrives in your inbox.
# ─────────────────────────────────────────────
VITE_WEB3FORMS_KEY=
